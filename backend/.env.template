# --- Application ---
NODE_ENV=development
PORT=3000

# --- Postgres (consumed directly by the postgres container) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_TEST_DB=

# --- Prisma / application datasource ---
# Local dev value uses localhost. When running fully dockerized, docker-compose.yml
# overrides these two to use the "postgres" service hostname instead.
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<db>?schema=public
TEST_DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<test_db>?schema=public

# --- Better Auth ---
# Two distinct secrets, one per isolated auth instance (employee vs customer).
# Each must be >= 32 chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_STAFF_SECRET=
BETTER_AUTH_CUSTOMER_SECRET=
# Base URL the app is served from; each auth instance's own basePath is appended to this.
BETTER_AUTH_URL=http://localhost:3000
# Email for the first super_admin EmployeeAccount, seeded via `npm run seed:super-admin`
# (standalone script, reads this directly — not wired through AppConfigService).
SUPER_ADMIN_EMAIL=
# The public-facing origin the app is served from — used to build absolute
# URLs (canonical page links, Open Graph image URLs) for crawlers. In dev this
# is the frontend dev server's origin; in prod it's the nginx-fronted host.
PUBLIC_APP_BASE_URL=http://localhost:5173

# --- SMTP (OTP delivery via Nodemailer) ---
# SMTP_SECURE must be the literal string "true" or "false".
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- MinIO / Media Storage ---
# Consumed directly by the minio container (mirrors POSTGRES_USER/PASSWORD).
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# S3-compatible endpoint the backend's S3 client uses for upload/delete/get —
# all server-to-server (the backend never redirects the browser to MinIO
# directly, so no presigning/public URL is needed).
# Local dev (backend on host): MinIO's published port. Once backend is dockerized: http://minio:9000.
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
# Dev-only: MinIO's root creds double as an S3 access key here. Replace with a
# scoped service account before any real deployment.
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
MINIO_BUCKET=cards-app-media
