# --- Application ---
NODE_ENV=development
PORT=3000

# --- Postgres (consumed directly by the postgres container) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_TEST_DB=

# --- Prisma / application datasource ---
# Local dev value uses localhost. When running fully dockerized, docker-compose.yml
# overrides these two to use the "postgres" service hostname instead.
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<db>?schema=public
TEST_DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<test_db>?schema=public

# --- Better Auth ---
# Two distinct secrets, one per isolated auth instance (employee vs customer).
# Each must be >= 32 chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_STAFF_SECRET=
BETTER_AUTH_CUSTOMER_SECRET=
# Base URL the app is served from; each auth instance's own basePath is appended to this.
BETTER_AUTH_URL=http://localhost:3000

# --- SMTP (OTP delivery via Nodemailer) ---
# SMTP_SECURE must be the literal string "true" or "false".
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
