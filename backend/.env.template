# --- Application ---
NODE_ENV=development
PORT=3000

# --- Postgres (consumed directly by the postgres container) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_TEST_DB=

# --- Prisma / application datasource ---
# Local dev value uses localhost. When running fully dockerized, docker-compose.yml
# overrides these two to use the "postgres" service hostname instead.
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<db>?schema=public
TEST_DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<test_db>?schema=public

# --- Better Auth ---
# Two distinct secrets, one per isolated auth instance (employee vs customer).
# Each must be >= 32 chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_STAFF_SECRET=
BETTER_AUTH_CUSTOMER_SECRET=
# Base URL the app is served from; each auth instance's own basePath is appended to this.
BETTER_AUTH_URL=http://localhost:3000
# Email for the first super_admin EmployeeAccount, seeded via `npm run seed:super-admin`
# (standalone script, reads this directly — not wired through AppConfigService).
SUPER_ADMIN_EMAIL=
# The public-facing origin the app is served from — used to build absolute
# URLs (canonical page links, Open Graph image URLs) for crawlers. In dev this
# is the frontend dev server's origin; in prod it's the nginx-fronted host.
PUBLIC_APP_BASE_URL=http://localhost:5173

# --- SMTP (OTP delivery via Nodemailer) ---
# SMTP_SECURE must be the literal string "true" or "false".
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- MinIO / Media Storage ---
# Consumed directly by the minio container (mirrors POSTGRES_USER/PASSWORD).
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# S3-compatible endpoint the backend's S3 client uses for upload/delete/get —
# all server-to-server (the backend never redirects the browser to MinIO
# directly, so no presigning/public URL is needed).
# Local dev (backend on host): MinIO's published port. Once backend is dockerized: http://minio:9000.
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
# Dev-only: MinIO's root creds double as an S3 access key here. Replace with a
# scoped service account before any real deployment.
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
MINIO_BUCKET=cards-app-media

# --- Google Wallet ("Add to Google Wallet" for e-cards) ---
# Optional — leave blank until provisioned; the feature errors clearly at
# call-time rather than the app failing to boot.
# Get Issuer ID from: https://pay.google.com/business/console -> Google Wallet API
# Service account needs the "Google Wallet API" role in Google Cloud IAM.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
# RSA private key PEM — replace newlines with \n when storing in a single-line env var.
GOOGLE_WALLET_PRIVATE_KEY=

# --- Apple Wallet ("Add to Apple Wallet" for e-cards) ---
# Optional — leave blank until provisioned; the feature errors clearly at
# call-time rather than the app failing to boot.
# Requires an Apple Developer account + Pass Type Certificate.
# APPLE_WALLET_PASS_TYPE_ID: e.g. pass.com.yourcompany.bizcard
# APPLE_WALLET_TEAM_ID: 10-char Apple Developer Team ID
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
# Pass Type Certificate (export from Keychain as .pem, replace newlines with \n).
APPLE_WALLET_CERT_PEM=
# Matching private key (PEM, replace newlines with \n).
APPLE_WALLET_KEY_PEM=
# Only needed if the private key above was exported passphrase-protected.
APPLE_WALLET_KEY_PASSPHRASE=
# Apple WWDR G4 cert — download from developer.apple.com/certificationauthority
# then: openssl x509 -inform der -in AppleWWDRCAG4.cer -out wwdr.pem
APPLE_WALLET_WWDR_PEM=

# --- Google/Apple Sign-In (customer OAuth login) ---
# Optional — leave blank until provisioned; Better Auth simply won't register
# the provider (the "Sign in with Google/Apple" buttons show a graceful error)
# until these are set, so the app boots fine without them.
# Google: https://console.cloud.google.com/apis/credentials -> OAuth client ID
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Apple: developer.apple.com -> Certificates, Identifiers & Profiles.
# APPLE_OAUTH_CLIENT_ID is the "Services ID" identifier (not the App ID).
# APPLE_OAUTH_KEY_ID + APPLE_OAUTH_PRIVATE_KEY come from a "Sign in with Apple"
# private key (.p8) generated under Keys — there's no separate client secret;
# one is signed at request time from these (see common/auth/apple-client-secret.ts).
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
# .p8 private key contents — replace newlines with \n when storing in a single-line env var.
APPLE_OAUTH_PRIVATE_KEY=
# Optional even among these — only needed for native-app (not web) verification.
APPLE_OAUTH_APP_BUNDLE_IDENTIFIER=
