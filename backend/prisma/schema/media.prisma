enum ImageSource {
  MINIO

  @@map("ImageSource")
}

model ImageMedia {
  id           String      @id @db.Uuid
  source       ImageSource
  storageKey   String
  originalName String
  extension    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  customer     Customer?

  smartCardTemplate     SmartCardTemplate?
  smartCardProfile      SmartCardProfile?
  smartCardFounder      SmartCardFounder?
  smartCardService      SmartCardService?
  smartCardGalleryImage SmartCardGalleryImage?

  @@map("ImageMedia")
}
