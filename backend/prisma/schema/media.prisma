enum MediaSource {
  MINIO

  @@map("MediaSource")
}

model Media {
  id           String      @id @db.Uuid
  source       MediaSource
  storageKey   String
  originalName String
  extension    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  customer     Customer?

  smartCardTemplate     SmartCardTemplate?
  smartCardProfile      SmartCardProfile?
  smartCardFounder      SmartCardFounder?
  smartCardService      SmartCardService?
  smartCardGalleryImage SmartCardGalleryImage?

  ecard             ECard?
  ecardGalleryImage ECardGalleryImage?
  ecardBrochure     ECardBrochureComponent?

  organisation Organisation?

  @@map("Media")
}
