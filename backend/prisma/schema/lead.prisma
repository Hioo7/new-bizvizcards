enum LeadSourceType {
  SMART_CARD
  E_CARD
  CARD_SCANNER
  MANUAL_ENTRY

  @@map("LeadSourceType")
}

enum OpportunityStage {
  LEAD
  QUALIFIED_LEAD
  NEEDS_ANALYSIS
  PROPOSAL_DEMO
  NEGOTIATION
  CLOSED_WON
  ONBOARDING
  ACTIVE_RETENTION
  CHURNED_CLOSED_LOST

  @@map("OpportunityStage")
}

enum ReminderStatus {
  PENDING
  TRIGGERED
  DISMISSED

  @@map("ReminderStatus")
}

model LeadFolder {
  id         String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  customerId String   @db.Uuid
  customer   Customer @relation("CustomerLeadFolders", fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  leads               Lead[]
  defaultForCustomers Customer[] @relation("CustomerDefaultLeadFolder")

  @@index([customerId])
  @@map("LeadFolder")
}

model Lead {
  id         String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  sourcedBy LeadSourceType    @default(MANUAL_ENTRY)
  stage     OpportunityStage?

  folderId String?     @db.Uuid
  folder   LeadFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  name              String
  email             String?
  countryDialCode   String?
  phoneNumber       String?
  note              String?
  company           String?
  profession        String?
  location          String?
  locationLatitude  Float?
  locationLongitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referenceNotes LeadReferenceNote[]
  reminders      LeadReminder[]

  @@index([customerId])
  @@index([folderId])
  @@map("Lead")
}

model LeadReferenceNote {
  id        String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  leadId    String   @db.Uuid
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@map("LeadReferenceNote")
}

model LeadReminder {
  id        String         @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  leadId    String         @db.Uuid
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title     String
  text      String?
  triggerAt DateTime
  status    ReminderStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([leadId])
  @@index([status, triggerAt])
  @@map("LeadReminder")
}
