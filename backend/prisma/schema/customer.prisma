model Customer {
  id         String          @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  accountId  String          @unique @db.Uuid
  account    CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  pfpMediaId String?         @unique @db.Uuid
  pfpMedia   Media?          @relation(fields: [pfpMediaId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  smartCards SmartCard[]
  ecards     ECard[]

  currentPlanId       String?               @db.Uuid
  currentPlan         Plan?                 @relation(fields: [currentPlanId], references: [id], onDelete: SetNull)
  planPurchaseHistory PlanPurchaseHistory[]

  defaultLeadFolderId String?     @db.Uuid
  defaultLeadFolder   LeadFolder? @relation("CustomerDefaultLeadFolder", fields: [defaultLeadFolderId], references: [id], onDelete: SetNull)

  leadFolders LeadFolder[] @relation("CustomerLeadFolders")
  leads       Lead[]

  organisationMemberships OrganisationMember[]
  createdOrganisations    Organisation[]       @relation("OrganisationCreatedBy")
  sentInvites             OrganisationInvite[] @relation("OrganisationInvitesSent")
  acceptedInvites         OrganisationInvite[] @relation("OrganisationInvitesAccepted")

  eventMemberships        EventMember[]
  eventGuestEntries       EventGuest[]               @relation("EventGuestCustomer")
  checkedInEventGuests    EventGuest[]               @relation("EventGuestCheckedInBy")
  scannedEventRedemptions EventTrackableRedemption[]

  linkedProductUnits ProductUnitLink[]

  addresses Address[]
  cart      Cart?
  orders    Order[]

  @@map("Customer")
}
