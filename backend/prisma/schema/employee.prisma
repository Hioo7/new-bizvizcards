model Employee {
  id        String          @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  accountId String          @unique @db.Uuid
  account   EmployeeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  createdSmartCards SmartCard[]

  @@map("Employee")
}
