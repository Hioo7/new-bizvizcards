enum ECardComponentType {
  ABOUT
  SOCIAL_LINKS
  GALLERY
  VIDEO
  TEAM
  WHATSAPP
  BROCHURE

  @@map("ECardComponentType")
}

model ECard {
  id                  String    @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  customerId          String    @db.Uuid
  customer            Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  endpoint            String    @unique
  createdByEmployeeId String?   @db.Uuid
  createdByEmployee   Employee? @relation(fields: [createdByEmployeeId], references: [id], onDelete: SetNull)

  // Optional back-reference to the organisation this specific card belongs
  // to (as opposed to the customer's own org membership) — at most one card
  // per customer per organisation (see @@unique below). This is how a
  // colleague's org-branded card is resolved for TEAM component listings,
  // independent of however many other (e.g. personal) cards they also own.
  organisationId String?       @db.Uuid
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)

  // Independent per-card identity — no longer derived from Customer.account,
  // since one customer can now own multiple cards, each with its own hero
  // data (e.g. a personal card vs. a company-branded card).
  heroName                String
  heroEmail               String
  heroCompanyName         String?
  heroProfilePhotoMediaId String? @unique @db.Uuid
  heroProfilePhoto        Media?  @relation(fields: [heroProfilePhotoMediaId], references: [id], onDelete: SetNull)

  phoneCountryDialCode     String?
  phoneNumber              String?
  isExchangeContactEnabled Boolean @default(true)
  // Per-card setting — when true, opening this card's public page
  // automatically triggers a vCard download for the visitor instead of
  // requiring a manual "Save Contact" tap.
  autoDownloadContact      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  components ECardComponent[]
  events     ECardEvent[]

  @@unique([customerId, organisationId])
  @@index([customerId])
  @@index([createdByEmployeeId])
  @@index([organisationId])
  @@map("ECard")
}

model ECardComponent {
  id        String             @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  ecardId   String             @db.Uuid
  ecard     ECard              @relation(fields: [ecardId], references: [id], onDelete: Cascade)
  type      ECardComponentType
  order     Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  about       ECardAboutComponent?
  socialLinks ECardSocialLinksComponent?
  gallery     ECardGalleryComponent?
  video       ECardVideoComponent?
  team        ECardTeamComponent?
  whatsapp    ECardWhatsAppComponent?
  brochure    ECardBrochureComponent?

  @@unique([ecardId, type])
  @@index([ecardId, order])
  @@map("ECardComponent")
}

model ECardAboutComponent {
  ecardComponentId String         @id @db.Uuid
  ecardComponent   ECardComponent @relation(fields: [ecardComponentId], references: [id], onDelete: Cascade)

  profession  String?
  shortNote   String?
  description String?
  aboutMe     String?

  @@map("ECardAboutComponent")
}

model ECardSocialLinksComponent {
  ecardComponentId String         @id @db.Uuid
  ecardComponent   ECardComponent @relation(fields: [ecardComponentId], references: [id], onDelete: Cascade)

  website   String?
  instagram String?
  facebook  String?
  twitter   String?
  linkedIn  String?

  @@map("ECardSocialLinksComponent")
}

model ECardWhatsAppComponent {
  ecardComponentId String         @id @db.Uuid
  ecardComponent   ECardComponent @relation(fields: [ecardComponentId], references: [id], onDelete: Cascade)

  phoneCountryDialCode String
  phoneNumber          String

  @@map("ECardWhatsAppComponent")
}

model ECardVideoComponent {
  ecardComponentId String         @id @db.Uuid
  ecardComponent   ECardComponent @relation(fields: [ecardComponentId], references: [id], onDelete: Cascade)

  title    String?
  videoUrl String

  @@map("ECardVideoComponent")
}

model ECardGalleryComponent {
  ecardComponentId String         @id @db.Uuid
  ecardComponent   ECardComponent @relation(fields: [ecardComponentId], references: [id], onDelete: Cascade)

  subGalleries ECardSubGallery[]

  @@map("ECardGalleryComponent")
}

model ECardSubGallery {
  id                 String                @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  galleryComponentId String                @db.Uuid
  galleryComponent   ECardGalleryComponent @relation(fields: [galleryComponentId], references: [ecardComponentId], onDelete: Cascade)
  title              String?
  order              Int                   @default(0)

  images ECardGalleryImage[]

  @@index([galleryComponentId])
  @@map("ECardSubGallery")
}

model ECardGalleryImage {
  id           String          @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  subGalleryId String          @db.Uuid
  subGallery   ECardSubGallery @relation(fields: [subGalleryId], references: [id], onDelete: Cascade)
  imageMediaId String          @unique @db.Uuid
  image        Media           @relation(fields: [imageMediaId], references: [id], onDelete: Restrict)
  order        Int             @default(0)

  @@index([subGalleryId])
  @@map("ECardGalleryImage")
}

model ECardBrochureComponent {
  ecardComponentId String         @id @db.Uuid
  ecardComponent   ECardComponent @relation(fields: [ecardComponentId], references: [id], onDelete: Cascade)

  pdfMediaId String @unique @db.Uuid
  pdf        Media  @relation(fields: [pdfMediaId], references: [id], onDelete: Restrict)

  @@map("ECardBrochureComponent")
}

model ECardTeamComponent {
  ecardComponentId String         @id @db.Uuid
  ecardComponent   ECardComponent @relation(fields: [ecardComponentId], references: [id], onDelete: Cascade)

  title String?

  members ECardTeamMember[]

  @@map("ECardTeamComponent")
}

model ECardTeamMember {
  id                   String             @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  teamComponentId      String             @db.Uuid
  teamComponent        ECardTeamComponent @relation(fields: [teamComponentId], references: [ecardComponentId], onDelete: Cascade)
  organisationMemberId String             @db.Uuid
  organisationMember   OrganisationMember @relation(fields: [organisationMemberId], references: [id], onDelete: Cascade)
  order                Int                @default(0)

  @@unique([teamComponentId, organisationMemberId])
  @@index([teamComponentId])
  @@map("ECardTeamMember")
}
