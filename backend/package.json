{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "pretest": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-test-fallback-plan.ts",
    "seed:test-fallback-plan": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-test-fallback-plan.ts",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json",
    "reconcile:auth-accounts": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/reconcile-orphaned-accounts.ts",
    "seed:super-admin": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-super-admin.ts",
    "seed:smart-card-templates": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-smart-card-templates.ts",
    "seed:og-preview-image": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-og-preview-image.ts",
    "seed:fallback-plan": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-fallback-plan.ts",
    "seed:dummy-members": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-dummy-members.ts",
    "seed:event-policy-defaults": "ts-node -r ./prisma/scripts/resolve-ts-extensions.js prisma/scripts/seed-event-policy-defaults.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "passkit-generator": "^3.5.7",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "setupFiles": [
      "dotenv/config"
    ],
    "maxWorkers": 1,
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
